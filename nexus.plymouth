[Plymouth Theme]
Name=NEXUS AI
Description=NEXUS AI Boot Splash - Neural Educational eXperience & Understanding System
ModuleName=two-step

[two-step]
ImageDir=/usr/share/plymouth/themes/nexus
HorizontalAlignment=.5
VerticalAlignment=.5
Transition=none
TransitionDuration=0.0
BackgroundStartColor=0x000000
BackgroundEndColor=0x000000
MessageBelowAnimation=false

[boot-up]
UseEndAnimation=false

[shutdown]
UseEndAnimation=false

[reboot]
UseEndAnimation=false
